# Voyage AI — embeddings (https://dashboard.voyageai.com/)
VOYAGE_API_KEY=your_voyage_api_key_here

# Anthropic — Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Absolute path to the directory holding the repos to index.
# Each immediate subdirectory is treated as one repo.
REPOS_ROOT=/absolute/path/to/repos

# Optional: ChromaDB collection name. Set this when indexing a different corpus
# in the same ChromaDB directory so they don't collide. Default: code_corpus
# COLLECTION_NAME=my_corpus
